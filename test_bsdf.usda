#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 0.01
    upAxis = "Y"
)

def Xform "World"
{
    def Mesh "DiffuseRed" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        float3[] extent = [(-0.5, -0.5, -0.5), (0.5, 0.5, 0.5)]
        int[] faceVertexCounts = [4, 4, 4, 4, 4, 4]
        int[] faceVertexIndices = [0,1,3,2, 2,3,5,4, 4,5,7,6, 6,7,1,0, 1,7,5,3, 6,0,2,4]
        point3f[] points = [(-0.5,-0.5,-0.5),(0.5,-0.5,-0.5),(-0.5,0.5,-0.5),(0.5,0.5,-0.5),(-0.5,0.5,0.5),(0.5,0.5,0.5),(-0.5,-0.5,0.5),(0.5,-0.5,0.5)]
        uniform token subdivisionScheme = "catmullClark"
        double3 xformOp:translate = (-3, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        rel material:binding = </World/Materials/DiffuseRedMat>
    }

    def Mesh "MetalGold" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        float3[] extent = [(-0.5, -0.5, -0.5), (0.5, 0.5, 0.5)]
        int[] faceVertexCounts = [4, 4, 4, 4, 4, 4]
        int[] faceVertexIndices = [0,1,3,2, 2,3,5,4, 4,5,7,6, 6,7,1,0, 1,7,5,3, 6,0,2,4]
        point3f[] points = [(-0.5,-0.5,-0.5),(0.5,-0.5,-0.5),(-0.5,0.5,-0.5),(0.5,0.5,-0.5),(-0.5,0.5,0.5),(0.5,0.5,0.5),(-0.5,-0.5,0.5),(0.5,-0.5,0.5)]
        uniform token subdivisionScheme = "catmullClark"
        double3 xformOp:translate = (-1, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        rel material:binding = </World/Materials/MetalGoldMat>
    }

    def Mesh "SmoothWhite" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        float3[] extent = [(-0.5, -0.5, -0.5), (0.5, 0.5, 0.5)]
        int[] faceVertexCounts = [4, 4, 4, 4, 4, 4]
        int[] faceVertexIndices = [0,1,3,2, 2,3,5,4, 4,5,7,6, 6,7,1,0, 1,7,5,3, 6,0,2,4]
        point3f[] points = [(-0.5,-0.5,-0.5),(0.5,-0.5,-0.5),(-0.5,0.5,-0.5),(0.5,0.5,-0.5),(-0.5,0.5,0.5),(0.5,0.5,0.5),(-0.5,-0.5,0.5),(0.5,-0.5,0.5)]
        uniform token subdivisionScheme = "catmullClark"
        double3 xformOp:translate = (1, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        rel material:binding = </World/Materials/SmoothWhiteMat>
    }

    def Mesh "RoughBlue" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        float3[] extent = [(-0.5, -0.5, -0.5), (0.5, 0.5, 0.5)]
        int[] faceVertexCounts = [4, 4, 4, 4, 4, 4]
        int[] faceVertexIndices = [0,1,3,2, 2,3,5,4, 4,5,7,6, 6,7,1,0, 1,7,5,3, 6,0,2,4]
        point3f[] points = [(-0.5,-0.5,-0.5),(0.5,-0.5,-0.5),(-0.5,0.5,-0.5),(0.5,0.5,-0.5),(-0.5,0.5,0.5),(0.5,0.5,0.5),(-0.5,-0.5,0.5),(0.5,-0.5,0.5)]
        uniform token subdivisionScheme = "catmullClark"
        double3 xformOp:translate = (3, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        rel material:binding = </World/Materials/RoughBlueMat>
    }

    def Scope "Materials"
    {
        def Material "DiffuseRedMat"
        {
            token outputs:surface.connect = </World/Materials/DiffuseRedMat/Shader.outputs:surface>
            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.85, 0.08, 0.05)
                float inputs:roughness = 0.6
                float inputs:metallic = 0.0
                token outputs:surface
            }
        }

        def Material "MetalGoldMat"
        {
            token outputs:surface.connect = </World/Materials/MetalGoldMat/Shader.outputs:surface>
            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.95, 0.75, 0.2)
                float inputs:roughness = 0.15
                float inputs:metallic = 1.0
                token outputs:surface
            }
        }

        def Material "SmoothWhiteMat"
        {
            token outputs:surface.connect = </World/Materials/SmoothWhiteMat/Shader.outputs:surface>
            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.9, 0.9, 0.9)
                float inputs:roughness = 0.05
                float inputs:metallic = 0.0
                float inputs:ior = 1.5
                token outputs:surface
            }
        }

        def Material "RoughBlueMat"
        {
            token outputs:surface.connect = </World/Materials/RoughBlueMat/Shader.outputs:surface>
            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.1, 0.15, 0.85)
                float inputs:roughness = 0.9
                float inputs:metallic = 0.0
                token outputs:surface
            }
        }
    }

    def Camera "Camera"
    {
        float focalLength = 10
        float horizontalAperture = 36
        float verticalAperture = 24
        float2 clippingRange = (0.1, 10000)
        double3 xformOp:translate = (0, 1.5, 8)
        double3 xformOp:rotateXYZ = (-10, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
    }
}
